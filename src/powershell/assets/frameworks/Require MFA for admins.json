          "deploymentAction": {
            "operationDefinition": {
              "values": [
                "@sys.write([@sys.project([{IncludeResponseBodyInException:true} GET /beta/identity/conditionalAccess/policies?$filter=displayName eq '[@displayName()]'],\"id\")],\"policyId\")",
                "{IncludeResponseBodyInException:true} PATCH /beta/identity/conditionalAccess/policies/[@sys.read(\"policyId\")] \\ {\r\n            \"conditions\": \r\n            {\r\n                \"applications\": \r\n                {\r\n                    \"includeApplications\": [[ [@sys.trimArray([@includeApplications()])] ]],\r\n                    \"excludeApplications\": [[ [@sys.trimArray([@excludeApplications()])] ]]\r\n                },\r\n                \"users\": \r\n                {\r\n                    \"excludeGroups\": [[ [@sys.trimArray([@excludeGroups()])] ]],\r\n                    \"excludeRoles\": [[ [@sys.trimArray([@excludeRoles()])] ]],\r\n                    \"excludeUsers\": [[ [@sys.trimArray([@excludeUsers()])] ]],\r\n                    \"includeGroups\": [[ [@sys.trimArray([@includeGroups()])] ]],\r\n                    \"includeRoles\": [[ [@sys.trimArray([@includeRoles()])] ]],\r\n                    \"includeUsers\": [[ [@sys.trimArray([@includeUsers()])] ]]\r\n                },\r\n                \"clientAppTypes\": [[ [@sys.trimArray([@clientAppTypes()])] ]],\r\n                \"locations\": \r\n                {\r\n                    \"excludeLocations\": [[ [@sys.trimArray([@excludeLocations()])] ]],\r\n                    \"includeLocations\": [[ [@sys.trimArray([@includeLocations()])] ]]\r\n                },\r\n                \"platforms\": \r\n                {\r\n                    \"includePlatforms\": [[ [@sys.trimArray([@includePlatforms()])] ]],\r\n                    \"excludePlatforms\": [[ [@sys.trimArray([@excludePlatforms()])] ]]\r\n                },\r\n                \"signInRiskLevels\": [[ [@sys.trimArray([@signInRiskLevels()])] ]],\r\n                \"userRiskLevels\": [[ [@sys.trimArray([@userRiskLevels()])] ]]\r\n            },\r\n            \"displayName\": \"[@displayName()]\",\r\n            \"state\": \"[@sys.first([@state()])]\",\r\n            \"grantControls\": \r\n            {\r\n                \"operator\": \"[@sys.first([@operator()])]\",\r\n                \"builtInControls\": [[ [@sys.trimArray([@builtInControls()])] ]],\r\n                \"customAuthenticationFactors\": [[]],\r\n                \"termsOfUse\": [[]]\r\n            }\r\n        }",
                "@sys.write([@sys.project([{IncludeResponseBodyInException:true} POST /beta/identity/conditionalAccess/policies[@sys.notexists(\"policyId\")] \\ {\r\n            \"conditions\": \r\n            {\r\n                \"applications\": \r\n                {\r\n                    \"includeApplications\": [[ [@sys.trimArray([@includeApplications()])] ]],\r\n                    \"excludeApplications\": [[ [@sys.trimArray([@excludeApplications()])] ]]\r\n                },\r\n                \"users\": \r\n                {\r\n                    \"excludeGroups\": [[ [@sys.trimArray([@excludeGroups()])] ]],\r\n                    \"excludeRoles\": [[ [@sys.trimArray([@excludeRoles()])] ]],\r\n                    \"excludeUsers\": [[ [@sys.trimArray([@excludeUsers()])] ]],\r\n                    \"includeGroups\": [[ [@sys.trimArray([@includeGroups()])] ]],\r\n                    \"includeRoles\": [[ [@sys.trimArray([@includeRoles()])] ]],\r\n                    \"includeUsers\": [[ [@sys.trimArray([@includeUsers()])] ]]\r\n                },\r\n                \"clientAppTypes\": [[ [@sys.trimArray([@clientAppTypes()])] ]],\r\n                \"locations\": \r\n                {\r\n                    \"excludeLocations\": [[ [@sys.trimArray([@excludeLocations()])] ]],\r\n                    \"includeLocations\": [[ [@sys.trimArray([@includeLocations()])] ]]\r\n                },\r\n                \"platforms\": \r\n                {\r\n                    \"includePlatforms\": [[ [@sys.trimArray([@includePlatforms()])] ]],\r\n                    \"excludePlatforms\": [[ [@sys.trimArray([@excludePlatforms()])] ]]\r\n                },\r\n                \"signInRiskLevels\": [[ [@sys.trimArray([@signInRiskLevels()])] ]],\r\n                \"userRiskLevels\": [[ [@sys.trimArray([@userRiskLevels()])] ]]\r\n            },\r\n            \"displayName\": \"[@displayName()]\",\r\n            \"state\": \"[@sys.first([@state()])]\",\r\n            \"grantControls\": \r\n            {\r\n                \"operator\": \"[@sys.first([@operator()])]\",\r\n                \"builtInControls\": [[ [@sys.trimArray([@builtInControls()])] ]],\r\n                \"customAuthenticationFactors\": [[]],\r\n                \"termsOfUse\": [[]]\r\n            }\r\n        }],\"id\")],\"policyId\")",
                "@sys.read(\"policyId\")"
              ],
              "lambdaDefinitions": [],
              "managedTenantOperationLogLevel": 0,
              "failOnError": false
            },
